{
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 17.0,
  "current_line_highlight": "gutter",
  "use_system_window_tabs": true,
  "linked_edits": true,
  "relative_line_numbers": "enabled",
  "sticky_scroll": { "enabled": true },
  "autosave": { "after_delay": { "milliseconds": 1000 } },
  "vim_mode": true,
  "prettier": { "allowed": true },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "bottom_dock_layout": "full",
  "which_key": {
    "enabled": true,
    "delay_ms": 400,
  },
  "diagnostics": {
    "inline": { "enabled": true },
    "lsp_pull_diagnostics": {
      "enabled": true,
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "status_bar": {
    "experimental.show": true,
  },
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "auto",
  },
  "file_types": {
    "tailwindcss": ["*.css", "*.css"],
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "buffer_line_height": {
    "custom": 1.75,
  },
  "inlay_hints": {
    "enabled": false,
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  "vim": {
    "show_edit_predictions_in_normal_mode": true,
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "use_regex_search": true,
  },
  "scroll_beyond_last_line": "off"
}
