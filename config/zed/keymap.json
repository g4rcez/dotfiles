[
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle",
      "ctrl-`": "terminal_panel::ToggleFocus",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "0": "vim::FirstNonWhitespace",
      "Backspace": "vim::FirstNonWhitespace",
      "ctrl-s": "workspace::Save",
      "ctrl-l": "pane::ActivateNextItem",
      "ctrl-h": "pane::ActivatePreviousItem",

      "space ,": "tab_switcher::Toggle",
      "space space": "file_finder::Toggle",
      "space f f": "file_finder::Toggle",
      "space f b": "tab_switcher::Toggle",
      "space f g": "pane::DeploySearch",
      "space f e": "project_panel::ToggleFocus",
      "space f s": "git_panel::ToggleFocus",
      "space f d": "diagnostics::Deploy",

      "space s e": "project_panel::ToggleFocus",
      "space s o": "project_panel::ToggleFocus",
      "space s g": "pane::DeploySearch",
      "space s w": "pane::DeploySearch",
      "space s s": "outline::Toggle",
      "space s S": "project_symbols::Toggle",
      "space s b": "buffer_search::Deploy",

      "space b d": "pane::CloseActiveItem",
      "space b o": "pane::CloseOtherItems",
      "space b r": "pane::ReopenClosedItem",

      "space q q": "pane::CloseActiveItem",
      "space q f": ["workspace::SendKeystrokes", ": q ! enter"],

      "space c f": "editor::Format",
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c o": "editor::OrganizeImports",
      "space c y": "workspace::CopyRelativePath",

      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDeclaration",
      "g i": "editor::GoToImplementation",
      "g t": "editor::GoToTypeDefinition",
      "g R": "editor::FindAllReferences",
      "K": "editor::Hover",
      "[ d": "editor::GoToPreviousDiagnostic",
      "] d": "editor::GoToDiagnostic",

      "space x x": "diagnostics::Deploy",
      "space x d": "editor::Hover",

      "] c": "editor::GoToHunk",
      "[ c": "editor::GoToPreviousHunk",
      "space h r": "git::Restore",
      "space h p": "editor::ExpandAllDiffHunks",

      "space g s": "git_panel::ToggleFocus",
      "space g g": "git_panel::ToggleFocus",
      "space g d": "editor::ExpandAllDiffHunks",
      "space g B": "editor::OpenPermalinkToLine",
      "space g b": "git::Branch",

      "space u h": "editor::ToggleInlayHints",
      "space t h": "editor::ToggleInlayHints",

      "+": ["workspace::SendKeystrokes", "ctrl-a"],
      "-": ["workspace::SendKeystrokes", "ctrl-x"],
      "escape": ["workspace::SendKeystrokes", ": n o h enter"],
      "J": ["workspace::SendKeystrokes", "m z J ` z"],
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "0": "vim::FirstNonWhitespace",
      "space s a": ["workspace::SendKeystrokes", ": s o r t enter"],
      "space s u": ["workspace::SendKeystrokes", ": s o r t space u enter"],
      "space s n": ["workspace::SendKeystrokes", ": s o r t space n enter"],
      "space c f": "editor::Format",
      "space c a": "editor::ToggleCodeActions",
      "space h r": "git::Restore",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-a": "editor::MoveToBeginningOfLine",
      "ctrl-e": "editor::MoveToEndOfLine",
      "ctrl-s": "workspace::Save",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "l": "project_panel::Open",
      "h": "project_panel::CollapseSelectedEntry",
      "q": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-d": "editor::SelectNext",
      "cmd-shift-d": "editor::SelectPrevious",
      "cmd-shift-l": ["editor::SelectAllMatches", { "regex": false }],
    },
  },
]
