#!/usr/bin/env bash

set -euo pipefail

APPNAME="amux"

STATE_DIR="$HOME/.config/$APPNAME"
STATE_FILE="$STATE_DIR/sessions.json"
DAEMON_STATE="$STATE_DIR/daemon-state.json"
DAEMON_PID="$STATE_DIR/daemon.pid"

mkdir -p "$STATE_DIR"
if [[ ! -f "$STATE_FILE" ]]; then
    echo "[]" > "$STATE_FILE"
fi

get_status() {
    local window_id="$1"
    local all_windows
    all_windows="$(tmux list-windows -a -F "#{window_id}" 2>/dev/null || true)"

    if ! echo "$all_windows" | grep -qxF "$window_id"; then
        echo "dead"
        return
    fi

    local cmd
    cmd="$(tmux display-message -t "$window_id" -p '#{pane_current_command}' 2>/dev/null || true)"
    if echo "$cmd" | grep -qiE '^(claude|gemini)$'; then
        echo "running"
    else
        echo "idle"
    fi
}

find_free_port() {
    local port=52700
    while lsof -ti :"$port" &>/dev/null; do
        (( port++ ))
    done
    echo "$port"
}

cmd_preview() {
    local window_id="${1:-}"
    tmux capture-pane -t "$window_id" -p -e 2>/dev/null || echo "(no content)"
}

prune_dead_sessions() {
    local all_windows
    all_windows="$(tmux list-windows -a -F "#{window_id}" 2>/dev/null || true)"

    local tmp
    tmp="$(jq --argjson live "$(echo "$all_windows" | jq -R . | jq -s .)" \
        '[.[] | select(.window_id as $w | $live | index($w) != null)]' \
        "$STATE_FILE")"
    echo "$tmp" > "$STATE_FILE"
}

select_window() {
    local window_id="$1"
    tmux select-window -t "$window_id"
}

cmd_kill() {
    local window_id="${1:-}"
    [[ -z "$window_id" ]] && { echo "Error: window_id required" >&2; exit 1; }

    tmux kill-window -t "$window_id" 2>/dev/null || true

    local tmp
    tmp="$(jq --arg wid "$window_id" '[.[] | select(.window_id != $wid)]' "$STATE_FILE")"
    echo "$tmp" > "$STATE_FILE"
}

cmd_new() {
    # Step 1 — pick worktree
    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"

    local worktree_list=""
    if [[ -n "$repo_root" ]]; then
        worktree_list="$(git worktree list --porcelain 2>/dev/null | grep '^worktree' | awk '{print $2}' || true)"
    else
        worktree_list="$(zoxide query -l 2>/dev/null | head -20 || true)"
    fi

    local fzf_out
    fzf_out="$(echo "$worktree_list" | fzf \
        $FZF_COLORS \
        --prompt="worktree> " \
        --border=sharp \
        --reverse \
        --height=100% \
        --border-label="$APPNAME: pick repo" \
        --header="Enter: pick or create worktree" \
        --print-query \
        --no-select-1 \
        2>/dev/null)" || true

    local query selected dir
    query="$(echo "$fzf_out" | sed -n '1p')"
    selected="$(echo "$fzf_out" | sed -n '2p')"

    if [[ -n "$selected" ]]; then
        dir="$selected"
    elif [[ -n "$query" && -n "$repo_root" ]]; then
        (cd "$repo_root" && bash "$HOME/dotfiles/bin/worktree" add "$query") || return 0
        local safe="${query//\//-}"
        local repo_name
        repo_name="$(basename "$repo_root")"
        dir="$HOME/.tmp/git/$repo_name/$safe"
    else
        return 0
    fi

    [[ -z "$dir" ]] && return 0

    # Step 2 — pick provider
    local provider
    provider="$(printf 'claude\ngemini\n' | fzf \
        $FZF_COLORS \
        --prompt="provider> " \
        --border=sharp \
        --reverse \
        --height=100% \
        --border-label="$APPNAME: pick provider")" || return 0

    [[ -z "$provider" ]] && return 0

    local repo
    repo="$(basename "$dir")"

    # Step 3 — check for duplicate
    local existing_wid
    existing_wid="$(jq -r --arg p "$provider" --arg d "$dir" \
        '.[] | select(.provider == $p and .dir == $d) | .window_id' \
        "$STATE_FILE" | head -1)"

    if [[ -n "$existing_wid" ]]; then
        local status
        status="$(get_status "$existing_wid")"
        if [[ "$status" != "dead" ]]; then
            select_window "$existing_wid"
            return 0
        fi
        # dead entry — remove it
        cmd_kill "$existing_wid" 2>/dev/null || true
    fi

    # Step 4 — create session
    local window_name="${provider}-${repo}"
    tmux new-session -d -s "$window_name" -c "$dir" 2>/dev/null || true
    local window_id
    window_id="$(tmux display-message -t "$window_name" -p '#{window_id}')"

    # Step 5 — launch CLI
    tmux send-keys -t "$window_id" "$provider" Enter

    # Step 6 — write to sessions.json
    local created_at
    created_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    local new_entry
    new_entry="$(jq -n \
        --arg id "${provider}-${repo}-$(date +%s)" \
        --arg provider "$provider" \
        --arg dir "$dir" \
        --arg repo "$repo" \
        --arg window_id "$window_id" \
        --arg created_at "$created_at" \
        '{id: $id, provider: $provider, dir: $dir, repo: $repo, window_id: $window_id, created_at: $created_at}')"
    local tmp
    tmp="$(jq --argjson entry "$new_entry" '. + [$entry]' "$STATE_FILE")"
    echo "$tmp" > "$STATE_FILE"

    tmux switch-client -t "$window_name" 2>/dev/null || tmux attach-session -t "$window_name"
}

_build_fzf_input() {
    local json="$1"
    local lines
    lines="$(echo "$json" | jq -r '.[] | [.window_id, .provider, .repo, .dir, .created_at] | @tsv')"
    [[ -z "$lines" ]] && return

    local now_epoch
    now_epoch="$(date +%s)"

    while IFS=$'\t' read -r window_id provider repo dir created_at; do
        local status age display_dir
        status="$(get_status "$window_id")"
        display_dir="${dir/#$HOME/\~}"

        local created_at_epoch diff
        if created_at_epoch="$(date -j -f '%Y-%m-%dT%H:%M:%SZ' "$created_at" '+%s' 2>/dev/null)"; then
            diff=$(( now_epoch - created_at_epoch ))
        else
            diff=0
        fi
        if (( diff < 60 )); then age="${diff}s"
        elif (( diff < 3600 )); then age="$(( diff / 60 ))m"
        else age="$(( diff / 3600 ))h"
        fi

        local indicator
        if [[ "$status" == "running" ]]; then indicator="●"
        elif [[ "$status" == "idle" ]]; then indicator="○"
        else indicator="✗"
        fi

        printf '%s\t%-6s  %-20s  %-30s  [%-7s]  %s\n' \
            "$window_id" "$indicator $provider" "$repo" "$display_dir" "$status" "$age"
    done <<< "$lines"
}

_run_picker() {
    local json="$1"       # filtered JSON array of sessions
    local prompt="$2"     # fzf prompt string
    local reload_cmd="$3" # command for --bind reload

    local session_count
    session_count="$(echo "$json" | jq 'length')"

    local FZF_PORT
    FZF_PORT="$(find_free_port)"

    (
        sleep 1
        while true; do
            curl -s "localhost:$FZF_PORT" -d "reload($reload_cmd)" 2>/dev/null || true
            sleep 3
        done
    ) &
    local RELOAD_PID=$!

    local fzf_input
    fzf_input="$(_build_fzf_input "$json")"

    local selected
    selected="$(echo "$fzf_input" | fzf \
        $FZF_COLORS \
        --prompt="$prompt" \
        --border=sharp \
        --reverse \
        --height=100% \
        --info=inline \
        --border-label="$APPNAME  [${session_count} sessions]" \
        --header="C-n: new  C-k: kill  C-r: reload" \
        --with-nth=2.. \
        --delimiter=$'\t' \
        --listen "$FZF_PORT" \
        --preview "bash $HOME/dotfiles/bin/$APPNAME _preview {1}" \
        --preview-window right:50%:wrap \
        --bind "ctrl-n:execute(bash $HOME/dotfiles/bin/$APPNAME new)+reload($reload_cmd)" \
        --bind "ctrl-k:execute-silent(bash $HOME/dotfiles/bin/$APPNAME kill {1})+reload($reload_cmd)" \
        --bind "ctrl-r:reload($reload_cmd)" \
        2>/dev/null)" || { kill "$RELOAD_PID" 2>/dev/null || true; return 0; }

    kill "$RELOAD_PID" 2>/dev/null || true

    [[ -z "$selected" ]] && return 0

    local window_id
    window_id="$(echo "$selected" | cut -f1)"
    [[ -z "$window_id" || "$window_id" == "("* ]] && return 0

    local session_name
    session_name="$(tmux display-message -t "$window_id" -p '#{session_name}' 2>/dev/null || true)"
    if [[ -n "$session_name" ]]; then
        tmux switch-client -t "$session_name"
    else
        select_window "$window_id"
    fi
}

cmd_pick() {
    prune_dead_sessions

    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"

    local json
    if [[ -n "$repo_root" ]]; then
        json="$(jq --arg root "$repo_root" '[.[] | select(.dir | startswith($root))]' "$STATE_FILE")"
    else
        json="$(cat "$STATE_FILE")"
    fi

    if [[ "$(echo "$json" | jq 'length')" -eq 0 ]]; then
        echo "No sessions available"
        return 0
    fi

    local reload_cmd
    if [[ -n "$repo_root" ]]; then
        reload_cmd="bash $HOME/dotfiles/bin/$APPNAME _list_repo '$repo_root'"
    else
        reload_cmd="bash $HOME/dotfiles/bin/$APPNAME _list"
    fi

    _run_picker "$json" "$APPNAME> " "$reload_cmd"
}

cmd_all() {
    prune_dead_sessions

    if [[ "$(jq 'length' "$STATE_FILE")" -eq 0 ]]; then
        echo "No sessions available"
        return 0
    fi

    _run_picker "$(cat "$STATE_FILE")" "$APPNAME all> " "bash $HOME/dotfiles/bin/$APPNAME _list"
}

# Internal: emit fzf-ready lines for reload bindings (all sessions)
cmd_list_internal() {
    prune_dead_sessions
    local json
    json="$(cat "$STATE_FILE")"
    _build_fzf_input "$json"
}

# Internal: emit fzf-ready lines filtered to a specific repo root
cmd_list_repo_internal() {
    local repo_root="${1:-}"
    prune_dead_sessions
    local json
    if [[ -n "$repo_root" ]]; then
        json="$(jq --arg root "$repo_root" '[.[] | select(.dir | startswith($root))]' "$STATE_FILE")"
    else
        json="$(cat "$STATE_FILE")"
    fi
    _build_fzf_input "$json"
}

cmd_daemon_run() {
    # Exit if tmux not running
    tmux info &>/dev/null || exit 0

    # Init daemon state if missing
    if [[ ! -f "$DAEMON_STATE" ]]; then
        echo "{}" > "$DAEMON_STATE"
    fi

    while true; do
        sleep 5

        local pairs
        pairs="$(jq -r '.[] | [.window_id, .repo] | @tsv' "$STATE_FILE" 2>/dev/null || true)"

        [[ -z "$pairs" ]] && continue

        while IFS=$'\t' read -r window_id repo; do
            (
                local current_status prev_status
                current_status="$(get_status "$window_id" 2>/dev/null || echo "dead")"
                prev_status="$(jq -r --arg wid "$window_id" '.[$wid] // "unknown"' "$DAEMON_STATE" 2>/dev/null || echo "unknown")"

                if [[ "$prev_status" == "running" && "$current_status" == "idle" ]]; then
                    bash "$HOME/dotfiles/bin/claude-notify" "Agent finished: $repo" &
                    bash "$HOME/.claude/hooks/notify.sh" "Agent finished: $repo" &
                elif [[ "$prev_status" == "idle" && "$current_status" == "running" ]]; then
                    bash "$HOME/dotfiles/bin/claude-notify" "Agent started: $repo" &
                    bash "$HOME/.claude/hooks/notify.sh" "Agent started: $repo" &
                fi

                local tmp
                tmp="$(jq --arg wid "$window_id" --arg status "$current_status" \
                    '.[$wid] = $status' "$DAEMON_STATE" 2>/dev/null || cat "$DAEMON_STATE")"
                echo "$tmp" > "$DAEMON_STATE"
            ) || true
        done <<< "$pairs"
    done
}

cmd_daemon_start() {
    if [[ -f "$DAEMON_PID" ]]; then
        local existing_pid
        existing_pid="$(cat "$DAEMON_PID")"
        if kill -0 "$existing_pid" 2>/dev/null; then
            echo "Daemon already running (PID $existing_pid)"
            return
        fi
    fi

    bash "$HOME/dotfiles/bin/$APPNAME" _daemon_run &
    disown
    echo $! > "$DAEMON_PID"
    echo "Daemon started (PID $(cat "$DAEMON_PID"))"
}

cmd_daemon_stop() {
    if [[ ! -f "$DAEMON_PID" ]]; then
        echo "Daemon not running (no PID file)"
        return
    fi

    local pid
    pid="$(cat "$DAEMON_PID")"
    kill "$pid" 2>/dev/null || true
    rm -f "$DAEMON_PID"
    echo "Daemon stopped"
}

cmd_help() {
    cat <<'EOF'
Usage: $APPNAME [command]

Commands:
  (none)          Open session picker filtered to current repo
  all             Open session picker for all repos
  new             Create a new AI session (pick worktree + provider)
  kill <id>       Kill a session by window ID
  daemon-start    Start background status-change notification daemon
  daemon-stop     Stop the background daemon

Picker keybindings:
  Enter           Switch to selected session
  C-n             Create a new session
  C-k             Kill selected session
  C-r             Reload session list
  Esc / C-c       Exit without switching

Session status indicators:
  ●  running      AI agent is active
  ○  idle         Window exists but agent is not running
  ✗  dead         Window no longer exists (pruned on open)
EOF
}

main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        new)           cmd_new "$@" ;;
        all)           cmd_all "$@" ;;
        kill)          cmd_kill "$@" ;;
        help|--help|-h) cmd_help ;;
        list)          cmd_pick ;;
        _list)         cmd_list_internal "$@" ;;
        _list_repo)    cmd_list_repo_internal "$@" ;;
        _preview)      cmd_preview "$@" ;;
        _daemon_run)   cmd_daemon_run "$@" ;;
        daemon-start)  cmd_daemon_start "$@" ;;
        daemon-stop)   cmd_daemon_stop "$@" ;;
        "")            cmd_help ;;
        *)             echo "Unknown command: $cmd. Run '$APPNAME help' for usage." >&2; exit 1 ;;
    esac
}

main "$@"
