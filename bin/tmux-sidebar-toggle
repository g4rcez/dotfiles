#!/usr/bin/env bash
# Toggle a right-docked sidebar pane showing the live agent list (herdr-style).
# It is a real split, so the content reflows beside it; closing reclaims the space.

sb=$(tmux list-panes -F '#{pane_id} #{@is_sidebar}' | awk '$2=="1"{print $1; exit}')

if [ -n "$sb" ]; then
  tmux kill-pane -t "$sb"
else
  tmux split-window -h -l 34 -c "#{pane_current_path}" "exec $HOME/dotfiles/bin/tmux-sidebar"
  tmux set -p @is_sidebar 1
  # leave focus IN the sidebar so j/k work immediately (no manual pane switch)
fi
