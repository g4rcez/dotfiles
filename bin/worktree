#!/usr/bin/env bash

set -euo pipefail

WORKTREE_BASE="$HOME/.tmp/git"

usage() {
    cat <<EOF
Usage: $(basename "$0") <command> [options]

Commands:
    add <branch> [base]    Create a worktree for <branch> (optionally from <base>)
    list                   List all worktrees for current repo
    remove <branch>        Remove a worktree
    prune                  Remove all worktrees for merged branches
    cd <branch>            Print the path to a worktree
    clean                  Remove all worktrees for current repo
    mux                    Pick a worktree with fzf and open/attach a tmux session
    overview               Show all worktrees with session status and git info

Examples:
    worktree add feature/new-login
    worktree add feature/hotfix main
    worktree add feature/experiment origin/develop
    worktree remove feature/new-login
    worktree cd feature/new-login
EOF
    exit 1
}

get_repo_name() {
    basename "$(git rev-parse --show-toplevel 2>/dev/null)" || {
        echo "Error: not in a git repository" >&2
        exit 1
    }
}

get_worktree_path() {
    local repo_name="$1"
    local branch="$2"
    local safe_branch="${branch//\//-}"
    echo "$WORKTREE_BASE/$repo_name/$safe_branch"
}

cmd_add() {
    local branch="${1:-}"
    local base="${2:-}"

    [[ -z "$branch" ]] && {
        echo "Error: branch name required" >&2
        usage
    }

    local repo_name
    repo_name="$(get_repo_name)"
    local worktree_path
    worktree_path="$(get_worktree_path "$repo_name" "$branch")"

    mkdir -p "$(dirname "$worktree_path")"

    if git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
        git worktree add "$worktree_path" "$branch"
    elif git show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null; then
        git worktree add "$worktree_path" "$branch"
    elif [[ -n "$base" ]]; then
        git worktree add -b "$branch" "$worktree_path" "$base"
    else
        git worktree add -b "$branch" "$worktree_path"
    fi
    echo ""
    echo "Worktree created at: $worktree_path"
}

# Internal: emit fzf-ready lines (path TAB display)
_cmd_list_lines() {
    local repo_name repo_base main_path
    repo_name="$(get_repo_name)"
    repo_base="$WORKTREE_BASE/$repo_name"
    main_path="$(git rev-parse --show-toplevel)"

    git worktree list | while read -r line; do
        if [[ "$line" == *"$repo_base"* ]] || [[ "$line" == "$main_path"* ]]; then
            local wt_path branch_raw branch display_path session_icon
            wt_path="$(echo "$line" | awk '{print $1}')"
            branch_raw="$(echo "$line" | sed -n 's/.*\[\(.*\)\]/\1/p')"
            [[ -n "$branch_raw" ]] && branch="$branch_raw" || branch="$(basename "$wt_path")"
            
            local session_name="${branch//\//-}"
            session_name="${session_name#-}"
            if tmux has-session -t "$session_name" 2>/dev/null; then
                session_icon="● "
            else
                session_icon="○ "
            fi

            display_path="${wt_path/#$HOME/\~}"
            printf '%s\t%s%-35s  %s\n' "$wt_path" "$session_icon" "$branch" "$display_path"
        fi
    done
}

_cmd_preview_wt() {
    local wt_path="$1"
    local session_name
    session_name="$(tmux list-sessions -F '#{session_name} #{pane_current_path}' 2>/dev/null |
        awk -v p="$wt_path" '$2 == p {print $1; exit}' || true)"

    # Catppuccin Mocha colors
    local pink=$'\e[38;2;243;139;168m'
    local mauve=$'\e[38;2;203;166;247m'
    local blue=$'\e[38;2;137;180;250m'
    local reset=$'\e[0m'
    local bold=$'\e[1m'

    _section_header() {
        local color="$1" label="$2"
        printf '%s%s══════ %s ══════%s\n' "$color" "$bold" "$label" "$reset"
    }

    if [[ -n "$session_name" ]]; then
        _section_header "$pink" "tmux: $session_name"
        tmux capture-pane -t "$session_name" -p -e 2>/dev/null || true
    else
        _section_header "$mauve" "git log"
        git -C "$wt_path" log --color=always \
            --pretty=format:"%C(yellow)%h%C(reset) %C(blue)%ad%C(reset) %C(dim white)%an%C(reset) %s%C(red)%d%C(reset)" \
            --date=short -10 2>/dev/null || true
        echo ""
        echo ""
        _section_header "$pink" "git status"
        git -C "$wt_path" status --short --branch --color=always 2>/dev/null || true
        echo ""
        _section_header "$blue" "directory"
        ls -laG "$wt_path" 2>/dev/null || true
    fi
}

_cmd_remove_wt() {
    local wt_path="$1"
    git worktree remove --force "$wt_path" 2>/dev/null || true
}

cmd_list() {
    local repo_name
    repo_name="$(get_repo_name)"

    local fzf_input
    fzf_input="$(_cmd_list_lines)"

    if [[ -z "$fzf_input" ]]; then
        echo "No worktrees found for $repo_name"
        return
    fi

    local selected
    selected="$(echo "$fzf_input" | fzf \
        $FZF_COLORS \
        --prompt="worktree> " \
        --border=sharp \
        --reverse \
        --height=100% \
        --border-label="worktrees: $repo_name" \
        --header="Enter: switch  Ctrl-D: delete" \
        --with-nth=2.. \
        --delimiter=$'\t' \
        --preview "bash $HOME/dotfiles/bin/worktree _preview {1}" \
        --preview-window right:70%:wrap \
        --bind "ctrl-d:execute-silent(bash $HOME/dotfiles/bin/worktree _remove {1})+reload(bash $HOME/dotfiles/bin/worktree _list_lines)" \
        2>/dev/null)" || return 0

    [[ -z "$selected" ]] && return 0

    local wt_path branch session_name
    wt_path="$(echo "$selected" | cut -f1)"
    branch="$(echo "$selected" | cut -f2 | awk '{print $2}')"
    session_name="${branch//\//-}"
    session_name="${session_name#-}"

    if ! tmux has-session -t "$session_name" 2>/dev/null; then
        tmux new-session -d -s "$session_name" -c "$wt_path"
    fi

    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$session_name"
    else
        tmux attach-session -t "$session_name"
    fi
}

cmd_prune() {
    local repo_name
    repo_name="$(get_repo_name)"
    local repo_base="$WORKTREE_BASE/$repo_name"

    echo "Fetching merged pull requests..."
    local merged_branches
    merged_branches=$(gh pr list --state merged --json headRefName --jq '.[].headRefName' 2>/dev/null || echo "")

    if [[ -z "$merged_branches" ]]; then
        echo "No merged branches found."
        return
    fi

    git worktree list | while read -r line; do
        local wt_path branch_raw branch
        wt_path="$(echo "$line" | awk '{print $1}')"
        [[ "$wt_path" != *"$repo_base"* ]] && continue

        branch_raw="$(echo "$line" | sed -n 's/.*\[\(.*\)\]/\1/p')"
        [[ -n "$branch_raw" ]] && branch="$branch_raw" || branch="$(basename "$wt_path")"

        if echo "$merged_branches" | grep -q "^$branch$"; then
            echo -n "Worktree for merged branch '$branch' found. Remove? [y/N] "
            read -r response
            if [[ "$response" =~ ^[Yy]$ ]]; then
                git worktree remove "$wt_path"
                local session_name="${branch//\//-}"
                session_name="${session_name#-}"
                if tmux has-session -t "$session_name" 2>/dev/null; then
                    tmux kill-session -t "$session_name"
                    echo "Removed worktree and killed tmux session: $session_name"
                else
                    echo "Removed worktree: $wt_path"
                fi
            fi
        fi
    done
    git worktree prune
}

cmd_remove() {
    local branch="${1:-}"

    [[ -z "$branch" ]] && {
        echo "Error: branch name required" >&2
        usage
    }

    local repo_name
    repo_name="$(get_repo_name)"
    local worktree_path
    worktree_path="$(get_worktree_path "$repo_name" "$branch")"

    if [[ -d "$worktree_path" ]]; then
        git worktree remove "$worktree_path"
        echo "Removed worktree: $worktree_path"
    else
        echo "Error: worktree not found at $worktree_path" >&2
        exit 1
    fi
}

cmd_cd() {
    local branch="${1:-}"

    if [[ -z "$branch" ]]; then
        git worktree list | awk '{print $1}' | head -1
        return
    fi

    local repo_name
    repo_name="$(get_repo_name)"
    local worktree_path
    worktree_path="$(get_worktree_path "$repo_name" "$branch")"

    if [[ -d "$worktree_path" ]]; then
        echo "$worktree_path"
    else
        echo "Error: worktree not found at $worktree_path" >&2
        exit 1
    fi
}

cmd_clean() {
    local repo_name
    repo_name="$(get_repo_name)"
    local repo_base="$WORKTREE_BASE/$repo_name"

    if [[ ! -d "$repo_base" ]]; then
        echo "No worktrees found for $repo_name"
        exit 0
    fi

    echo "Removing all worktrees for $repo_name..."

    for dir in "$repo_base"/*; do
        [[ -d "$dir" ]] || continue
        git worktree remove "$dir" 2>/dev/null && echo "Removed: $dir" || true
    done

    git worktree prune
    rmdir "$repo_base" 2>/dev/null || true

    echo "Done"
}

cmd_mux() {
    local repo_name
    repo_name="$(get_repo_name)"
    local repo_base="$WORKTREE_BASE/$repo_name"
    local main_path
    main_path="$(git rev-parse --show-toplevel)"

    local selected
    selected="$(git worktree list | while read -r line; do
        if [[ "$line" == *"$repo_base"* ]] || [[ "$line" == "$main_path"* ]]; then
            local wt_path branch_raw branch display
            wt_path="$(echo "$line" | awk '{print $1}')"
            branch_raw="$(echo "$line" | sed -n 's/.*\[\(.*\)\]/\1/p')"
            if [[ -n "$branch_raw" ]]; then
                branch="$branch_raw"
            else
                branch="$(basename "$wt_path")"
            fi
            printf "%-40s  %s\n" "$branch" "$wt_path"
        fi
    done | fzf --prompt='worktree> ')"

    [[ -z "$selected" ]] && return 0

    local selected_path branch_field session_name
    selected_path="$(echo "$selected" | awk '{print $NF}')"
    branch_field="$(echo "$selected" | awk '{print $1}')"
    session_name="${branch_field//\//-}"
    session_name="${session_name#-}"

    if ! tmux has-session -t "$session_name" 2>/dev/null; then
        tmux new-session -d -s "$session_name" -c "$selected_path"
    fi

    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$session_name"
    else
        tmux attach-session -t "$session_name"
    fi
}

cmd_overview() {
    local repo_name
    repo_name="$(get_repo_name)"
    local repo_base="$WORKTREE_BASE/$repo_name"
    local main_path
    main_path="$(git rev-parse --show-toplevel)"

    printf '%-35s  %-8s  %-6s  %s\n' "BRANCH" "SESSION" "DIRTY" "AHEAD/BEHIND"
    printf '%-35s  %-8s  %-6s  %s\n' "------" "-------" "-----" "------------"

    git worktree list | while read -r line; do
        local wt_path branch_raw branch
        wt_path="$(echo "$line" | awk '{print $1}')"
        if [[ "$wt_path" != *"$repo_base"* && "$wt_path" != "$main_path" && "$wt_path" != "$main_path/"* ]]; then
            continue
        fi

        branch_raw="$(echo "$line" | sed -n 's/.*\[\(.*\)\]/\1/p')"
        [[ -n "$branch_raw" ]] && branch="$branch_raw" || branch="$(basename "$wt_path")"

        local session_name="${branch//\//-}"
        session_name="${session_name#-}"
        if tmux has-session -t "$session_name" 2>/dev/null; then
            local session_status="●"
        else
            local session_status="○"
        fi

        local dirty_count
        dirty_count="$(git -C "$wt_path" status --short 2>/dev/null | wc -l | tr -d ' ')"

        local ahead_behind
        ahead_behind="$(git -C "$wt_path" rev-list --left-right --count "HEAD...@{upstream}" 2>/dev/null | tr '\t' '/' || echo "?/?") "

        printf '%-35s  %-8s  %-6s  %s\n' "$branch" "$session_status" "$dirty_count" "$ahead_behind"
    done | column -t
}

origin() {
    cd "$(git worktree list | awk '{print $1}' | head -1)"
}

main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
    add) cmd_add "$@" ;;
    list | ls) cmd_list "$@" ;;
    remove | rm) cmd_remove "$@" ;;
    prune) cmd_prune "$@" ;;
    cd) cmd_cd "$@" ;;
    clean) cmd_clean "$@" ;;
    origin) origin "$@" ;;
    mux) cmd_mux "$@" ;;
    overview) cmd_overview "$@" ;;
    _preview) _cmd_preview_wt "$@" ;;
    _remove) _cmd_remove_wt "$@" ;;
    _list_lines) _cmd_list_lines "$@" ;;
    *) usage ;;
    esac
}

main "$@"
