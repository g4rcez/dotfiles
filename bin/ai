#!/usr/bin/env bash
set -euo pipefail

# Resolve script location (follow symlinks)
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
DOTFILES_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")/.." && pwd)"

CONFIG_FILE="$HOME/.config/ai-dotfiles/projects.json"
PROVIDER="${AI_PROVIDER:-claude}"

# Check dependencies
if ! command -v jq &>/dev/null; then
  echo "error: jq not found" >&2
  exit 1
fi

save_project() {
  local path="$1"
  local provider="$2"
  mkdir -p "$(dirname "$CONFIG_FILE")"
  if [ ! -f "$CONFIG_FILE" ]; then
    echo '{"projects":[]}' > "$CONFIG_FILE"
  fi
  local updated
  updated="$(jq --arg path "$path" --arg provider "$provider" \
    'if (.projects | map(.path) | index($path)) != null
     then .projects |= map(if .path == $path then {path: $path, provider: $provider} else . end)
     else .projects += [{path: $path, provider: $provider}]
     end' "$CONFIG_FILE")"
  echo "$updated" > "$CONFIG_FILE"
}

cmd_agents() {
  local src="$DOTFILES_DIR/.ai/guidelines"
  if [ ! -d "$src" ]; then
    echo "error: no guidelines dir" >&2
    exit 1
  fi
  find "$src" -maxdepth 1 -type f -exec cp {} . \;
  save_project "$PWD" "$PROVIDER"
  echo "agents: ok"
}

cmd_subagents() {
  local src="$DOTFILES_DIR/.ai/agents"
  if [ ! -d "$src" ]; then
    return 0
  fi
  local dest="./$PROVIDER/agents"
  mkdir -p "$dest"
  for agent_dir in "$src"/*/; do
    [ -d "$agent_dir" ] || continue
    cp -r "$agent_dir" "$dest/"
  done
  save_project "$PWD" "$PROVIDER"
  echo "subagents: ok"
}

cmd_skills() {
  local skill_name="${1:-}"
  local dest="./$PROVIDER/skills"

  local sources=()
  local s
  for s in "$DOTFILES_DIR/.ai/skills" "$HOME/.claude/skills" "$PWD/.claude/skills"; do
    if [[ -d "$s" ]]; then
      sources+=("$s")
    fi
  done

  if [[ ${#sources[@]} -eq 0 ]]; then
    echo "error: no skills dirs found" >&2
    exit 1
  fi

  local skill_path=""

  if [[ -z "$skill_name" ]]; then
    if ! command -v fzf &>/dev/null; then
      echo "error: fzf not found" >&2
      exit 1
    fi
    local preview="$HOME/dotfiles/bin/lessfilter.sh {}/SKILL.md"
    local selected
    selected="$(find "${sources[@]}" -mindepth 1 -maxdepth 1 -type d | sort -u | fzf --prompt='skill: ' --preview "$preview" --preview-window 'right,65%')"
    skill_path="$selected"
    skill_name="$(basename "$selected")"
  else
    for s in "$PWD/.claude/skills" "$HOME/.claude/skills" "$DOTFILES_DIR/.ai/skills"; do
      if [[ -d "$s/$skill_name" ]]; then
        skill_path="$s/$skill_name"
        break
      fi
    done
  fi

  if [[ -z "$skill_name" || -z "$skill_path" ]]; then
    echo "error: unknown skill '${skill_name:-}'" >&2
    exit 1
  fi

  mkdir -p "$dest"
  cp -r "$skill_path" "$dest/"
  save_project "$PWD" "$PROVIDER"
  echo "skills: ok ($skill_name)"
}

cmd_update() {
  if [ ! -f "$CONFIG_FILE" ]; then
    echo "no projects tracked"
    return 0
  fi
  local length
  length="$(jq '.projects | length' "$CONFIG_FILE")"
  for i in $(seq 0 $((length - 1))); do
    local path provider
    path="$(jq -r ".projects[$i].path" "$CONFIG_FILE")"
    provider="$(jq -r ".projects[$i].provider" "$CONFIG_FILE")"
    if [ ! -d "$path" ]; then
      echo "warn: $path not found, skipping" >&2
      continue
    fi
    echo "update: $path"
    (
      cd "$path"
      PROVIDER="$provider"
      # Run commands without re-saving (paths already tracked)
      local src_guidelines="$DOTFILES_DIR/.ai/guidelines"
      if [ -d "$src_guidelines" ]; then
        find "$src_guidelines" -maxdepth 1 -type f -exec cp {} . \;
      fi
      local src_agents="$DOTFILES_DIR/.ai/agents"
      if [ -d "$src_agents" ]; then
        local dest_agents="./$PROVIDER/agents"
        mkdir -p "$dest_agents"
        for agent_dir in "$src_agents"/*/; do
          [ -d "$agent_dir" ] || continue
          cp -r "$agent_dir" "$dest_agents/"
        done
      fi
      local src_skills="$DOTFILES_DIR/.ai/skills"
      if [ -d "$src_skills" ]; then
        local dest_skills="./$PROVIDER/skills"
        mkdir -p "$dest_skills"
        for skill_dir in "$src_skills"/*/; do
          [ -d "$skill_dir" ] || continue
          cp -r "$skill_dir" "$dest_skills/"
        done
      fi
    )
  done
  echo "done"
}

cmd_list() {
  if ! command -v fzf &>/dev/null; then
    echo "error: fzf not found" >&2
    exit 1
  fi
  local entries=()
  local skills_dir="$DOTFILES_DIR/.ai/skills"
  local agents_dir="$DOTFILES_DIR/.ai/agents"
  local subagents_dir="$DOTFILES_DIR/.ai/subagents"
  local guidelines_dir="$DOTFILES_DIR/.ai/guidelines"
  local home_skills_dir="$HOME/.$PROVIDER/skills"
  local proj_skills_dir="./.$PROVIDER/skills"

  if [ -d "$skills_dir" ]; then
    for d in "$skills_dir"/*/; do
      [ -d "$d" ] || continue
      entries+=("[skill] $(basename "$d")"$'\t'"${d%/}")
    done
  fi
  if [ -d "$home_skills_dir" ]; then
    for d in "$home_skills_dir"/*/; do
      [ -d "$d" ] || continue
      entries+=("[skill:~] $(basename "$d")"$'\t'"${d%/}")
    done
  fi
  if [ -d "$proj_skills_dir" ]; then
    local proj_abs dotf_abs home_abs
    proj_abs="$(cd "$proj_skills_dir" 2>/dev/null && pwd)"
    dotf_abs="$(cd "$skills_dir"      2>/dev/null && pwd)"
    home_abs="$(cd "$home_skills_dir" 2>/dev/null && pwd)"
    if [ "$proj_abs" != "$dotf_abs" ] && [ "$proj_abs" != "$home_abs" ]; then
      for d in "$proj_skills_dir"/*/; do
        [ -d "$d" ] || continue
        entries+=("[skill:.] $(basename "$d")"$'\t'"${d%/}")
      done
    fi
  fi
  if [ -d "$subagents_dir" ]; then
    for d in "$subagents_dir"/*/; do
      [ -d "$d" ] || continue
      entries+=("[subagent] $(basename "$d")"$'\t'"${d%/}")
    done
  fi
  if [ -d "$agents_dir" ]; then
    for d in "$agents_dir"/*/; do
      [ -d "$d" ] || continue
      entries+=("[agent] $(basename "$d")"$'\t'"${d%/}")
    done
  fi
  if [ -d "$guidelines_dir" ]; then
    for f in "$guidelines_dir"/*; do
      [ -f "$f" ] || continue
      entries+=("[guideline] $(basename "$f")"$'\t'"$f")
    done
  fi
  if [ ${#entries[@]} -eq 0 ]; then
    echo "nothing found"
    return 0
  fi
  printf '%s\n' "${entries[@]}" | fzf --ansi \
    --height 95% \
    --info=inline \
    --layout=reverse \
    --delimiter $'\t' \
    --with-nth 1 \
    --preview-window right,75% \
    --preview "
      entry={1}
      path={2}
      if [[ \"\$entry\" == \[skill* ]]; then
        bat --theme OneHalfDark --color=always \"\$path/SKILL.md\" 2>/dev/null \
          || cat \"\$path/SKILL.md\" 2>/dev/null \
          || echo 'No SKILL.md found'
      elif [[ \"\$entry\" == \[subagent\]* ]] || [[ \"\$entry\" == \[agent\]* ]]; then
        first_file=\$(ls \"\$path/\" 2>/dev/null | head -1)
        if [ -n \"\$first_file\" ]; then
          bat --theme OneHalfDark --color=always \"\$path/\$first_file\" 2>/dev/null \
            || cat \"\$path/\$first_file\"
        else
          echo 'No files found'
        fi
      elif [[ \"\$entry\" == \[guideline\]* ]]; then
        bat --theme OneHalfDark --color=always \"\$path\" 2>/dev/null \
          || cat \"\$path\" 2>/dev/null \
          || echo 'No file found'
      fi
    "
}

cmd_open() {
  local cmd="${AI_COMMAND_PROMPT:-claude --dangerously-skip-permissions}"
  eval exec "$cmd" "$@"
}

_ai_find_ai_proc() {
  local root="$1"
  local snap="$2"
  local -a frontier=("$root")
  local depth=0
  local p cpid argv0 argv1 b0 b1
  local -a nxt=()
  while [ "${#frontier[@]}" -gt 0 ] && [ "$depth" -lt 4 ]; do
    nxt=()
    for p in "${frontier[@]}"; do
      while read -r cpid _ argv0 argv1 _rest; do
        [ -z "$cpid" ] && continue
        b0="${argv0##*/}"; b1="${argv1##*/}"
        if [[ "$b0" =~ ^(claude|gemini|codex|opencode)$ ]]; then
          printf '%s %s' "$b0" "$cpid"; return
        fi
        if [[ "$b1" =~ ^(claude|gemini|codex|opencode)$ ]]; then
          printf '%s %s' "$b1" "$cpid"; return
        fi
        nxt+=("$cpid")
      done < <(awk -v p="$p" '$2==p{print $0}' <<< "$snap")
    done
    if (( ${#nxt[@]} == 0 )); then break; fi
    frontier=("${nxt[@]}")
    (( depth++ ))
  done
}

cmd_sessions_rows() {
  local current_pane="${TMUX_PANE:-}"
  local ps_snap
  ps_snap=$(ps -A -o pid=,ppid=,args= 2>/dev/null)
  while IFS='|' read -r pane_id sess win pane win_name path pid pane_title; do
    [ "$pane_id" = "$current_pane" ] && continue
    local found found_name ai_pid
    found=$(_ai_find_ai_proc "$pid" "$ps_snap")
    [ -z "$found" ] && continue
    found_name="${found%% *}"
    ai_pid="${found##* }"
    local short_path="${path/#$HOME/~}"
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$pane_id" "$sess:$win.$pane" "$found_name" "$short_path" "$win_name" "$pane_title" "$ai_pid"
  done < <(tmux list-panes -a -F \
    '#{pane_id}|#{session_name}|#{window_index}|#{pane_index}|#{window_name}|#{pane_current_path}|#{pane_pid}|#{pane_title}')
}

cmd_pane_status() {
  local ai_pid="$1"
  local pane_id="$2"
  local child_count
  child_count=$(ps -A -o ppid=,comm= 2>/dev/null | \
    awk -v p="$ai_pid" '$1+0==p+0 && $2!~/^node/{c++} END{print c+0}')
  local at_prompt=0
  local last_line
  last_line=$(tmux capture-pane -p -t "$pane_id" 2>/dev/null | grep -v '^\s*$' | tail -1)
  [[ "$last_line" =~ ^[[:space:]]*\> ]] && at_prompt=1
  if   (( child_count > 0 )) && (( at_prompt )); then printf 'background'
  elif (( child_count > 0 ));                    then printf 'running'
  elif (( at_prompt ));                          then printf 'waiting'
  else                                                printf 'idle'
  fi
}

cmd_preview() {
  local pane_id="$1" ai_name="$2" short_path="$3" win_name="$4" pane_title="$5" ai_pid="$6"
  printf '\033[1;33m %s\033[0m  \033[1m%s\033[0m\n' "$ai_name" "$win_name"
  case "$pane_title" in
    ''|null) ;;
    *) printf ' \033[36m%s\033[0m\n' "$pane_title" ;;
  esac
  local status sc
  status=$(cmd_pane_status "$ai_pid" "$pane_id")
  case "$status" in
    running)    sc='\033[1;32m' ;;
    background) sc='\033[1;35m' ;;
    waiting)    sc='\033[1;33m' ;;
    *)          sc='\033[2m'    ;;
  esac
  printf " ${sc}%s\033[0m  \033[2m%s\033[0m\n" "$status" "$short_path"
  printf '\033[2m ──────────────────────────────────────────────────\033[0m\n\n'
  tmux capture-pane -ep -t "$pane_id" -S -200
}

cmd_sessions() {
  if ! command -v tmux &>/dev/null; then
    echo "error: tmux not found" >&2; exit 1
  fi
  if ! command -v fzf &>/dev/null; then
    echo "error: fzf not found" >&2; exit 1
  fi
  local rows
  rows=$(cmd_sessions_rows)
  if [ -z "$rows" ]; then
    echo "no ai sessions"
    return 0
  fi
  local self="$0"
  local selection
  selection=$(
    printf '%s\n' "$rows" \
      | fzf \
          --cycle \
          --border "sharp" \
          --border-label "ai sessions" \
          --reverse \
          --no-sort \
          --info inline \
          --height 100% \
          --color=dark \
          --color='bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8' \
          --color='fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc' \
          --color='marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8' \
          --prompt "AI sessions > " \
          --header "ctrl-d: kill pane" \
          --delimiter $'\t' \
          --with-nth '2..5' \
          --preview "$self --_preview {1} {3} {4} {5} {6} {7}" \
          --preview-window right,65% \
          --bind "ctrl-d:execute-silent(tmux kill-pane -t {1})+reload($self --_sessions-rows)"
  )
  [ -z "$selection" ] && return 0
  local target
  target=$(cut -f1 <<< "$selection")
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$target"
  else
    local sess
    sess=$(tmux display -t "$target" -p '#{session_name}')
    tmux attach -t "$sess" \; select-pane -t "$target"
  fi
}

usage() {
  local exit_code="${1:-1}"
  cat >&2 <<EOF
Usage: ai [--provider <name>] [command]

Commands:
  (none)      open the AI for the current provider
  agents      deploy guidelines to cwd
  subagents   deploy agents to ./<provider>/agents/
  skills      deploy a skill to ./<provider>/skills/
  update      re-sync all tracked projects
  list        browse available items with fzf
  sessions    switch to a tmux pane running an AI CLI
  help        show this help

Options:
  --provider  AI provider (default: claude, or \$AI_PROVIDER)
  -h, --help  show this help
EOF
  exit "$exit_code"
}

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --provider)
      shift
      PROVIDER="$1"
      shift
      ;;
    -h|--help|help)   usage 0 ;;
    agents)           shift; cmd_agents "$@"; exit 0 ;;
    subagents)        shift; cmd_subagents "$@"; exit 0 ;;
    skills)           shift; cmd_skills "$@"; exit 0 ;;
    update)           shift; cmd_update "$@"; exit 0 ;;
    list)             shift; cmd_list "$@"; exit 0 ;;
    sessions)         shift; cmd_sessions "$@"; exit 0 ;;
    --_sessions-rows) cmd_sessions_rows; exit 0 ;;
    --_preview)       shift; cmd_preview "$@"; exit 0 ;;
    *)         break ;;
  esac
done

cmd_open "$@"
